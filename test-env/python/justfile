# Python test-env tasks. Run `just` (or `just -l`) to list.
# Recipes exec inside a long-running dev container — fast iteration.

set shell := ["bash", "-uc"]

run := "./run.sh"

# Default: show available recipes.
default:
    @just --list

# Start the long-running dev container in the background.
up:
    {{run}} up

# Stop and remove the dev container.
down:
    {{run}} down

# Container status.
ps:
    {{run}} ps

# Build / rebuild the runner image (after pyproject.toml or Dockerfile change).
rebuild:
    {{run}} --rebuild

# Ruff linter.
lint:
    {{run}} ruff check .

# Lint the test-env scaffolding (shell scripts + Dockerfile + YAML).
lint-env:
    {{run}} shellcheck run.sh
    {{run}} hadolint docker/Dockerfile
    {{run}} yamllint docker/docker-compose.yml

# Ruff auto-fix where possible.
fix:
    {{run}} ruff check --fix .

# Assert Ruff formatting (CI-style).
format-check:
    {{run}} ruff format --check .

# Apply Ruff formatting.
format:
    {{run}} ruff format .

# Static type check.
typecheck:
    {{run}} mypy

# Unit tests.
test:
    {{run}} pytest -q

# Unit tests with coverage.
cov:
    {{run}} pytest --cov=sample --cov-report=term-missing

# Full local CI loop: env-lint + lint + format check + typecheck + tests.
ci: lint-env lint format-check typecheck test

# Interactive shell inside the running container.
shell:
    {{run}} shell
